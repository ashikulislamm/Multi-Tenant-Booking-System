		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api",
			"type": "string"
		},
		{
			"key": "adminToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "employeeToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "organizationId",
			"value": "",
			"type": "string"
		},
		{
			"key": "resourceId",
			"value": "",
